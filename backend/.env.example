NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: use SQLite (DB_PATH is required when DATABASE_URL is absent)
DB_PATH=./tasks.db

# Production (Railway / any Postgres): set DATABASE_URL and omit DB_PATH.
# Railway injects this automatically when you link the Postgres plugin.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL in production
# e.g. CORS_ORIGIN=https://task-manager-xyz.vercel.app
CORS_ORIGIN=http://localhost:4200
